{
  "name": "e-audit",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "start:frontend": "ng serve",
    "build:frontend": "ng build",
    "test:frontend": "ng test",
    "start:backend": "npm --prefix backend run start:dev",
    "build:backend": "npm --prefix backend run build",
    "test:backend": "npm --prefix backend run test",
    "lint:backend": "npm --prefix backend run lint",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "20.3.12",
    "@angular/compiler": "20.3.12",
    "@angular/core": "20.3.12",
    "@angular/forms": "20.3.12",
    "@angular/platform-browser": "20.3.12",
    "@angular/router": "20.3.12",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0",
    "@angular/animations": "20.3.12",
    "@angular/material": "20.2.10",
    "@angular/cdk": "20.2.10"
  },
  "devDependencies": {
    "@angular/build": "20.3.12",
    "@angular/cli": "20.3.12",
    "@angular/compiler-cli": "20.3.12",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2"
  }
}
